    "login_button": "[data-testid='login-submit']",
    "cart_button": "[data-testid='nav-cart']",
    "checkout_button": "[data-testid='checkout-start']",
    "payment_method_card": "[data-testid='payment-method-card']",
    "payment_method_wallet": "[data-testid='payment-method-wallet']",
    "card_number": "[data-testid='card-number']",
    "card_expiry": "[data-testid='card-expiry']",
    "card_cvv": "[data-testid='card-cvv']",
    "pay_now": "[data-testid='pay-now']",
    "payment_status": "[data-testid='payment-status']",
    "order_confirmation": "[data-testid='order-confirmation']",
    "payment_error": "[data-testid='payment-error']"
  },
  "payment": {
    "valid_card": {
      "number": "4111111111111111",
      "expiry": "12/30",
      "cvv": "123"
