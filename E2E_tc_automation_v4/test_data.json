    "success_text": "Success"
  },
  "api": {
    "base_url": "https://your-api.example",
    "order_status_path_template": "/orders/{order_id}",
    "auth_token": ""
  },
  "db": {
    "enabled": false,
    "host": "localhost",
    "port": 5432,
    "database": "",
    "user": "",
    "password": "",
    "order_status_query": "SELECT payment_status FROM payments WHERE order_id = %s ORDER BY updated_at DESC LIMIT 1"
  }
